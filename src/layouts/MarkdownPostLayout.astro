---
import DateTimeComponent from "../components/DateTimeComponent.astro";
import { getCanonicalUrl } from "../scripts/canonical";
import BaseLayout from "./BaseLayout.astro";
import { Disqus } from "astro-disqus";

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: undefined | string;
    tags: string[];
    imageAlt?: string | undefined;
    image?: {
      src: string;
      width: number;
      height: number;
    } | undefined;
  };
}
const { frontmatter } = Astro.props;

const description = frontmatter.description;
const image = frontmatter.image;
const title = frontmatter.title;

const canonicalUrl = getCanonicalUrl(Astro.url, Astro.site);
const canonicalUrlString = canonicalUrl?.toString();

const getAbsoluteUrl = (path: string) => new URL(path, Astro.site ?? Astro.url).toString();

const postPathSegments = Astro.url.pathname.replace(/^\/|\/$/g, "").split("/");
const yearSegment = postPathSegments[0];
const hasYearSegment = /^\d{4}$/.test(yearSegment ?? "");

const archiveBreadcrumbs = hasYearSegment
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Archive",
          item: getAbsoluteUrl("/archive"),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: yearSegment,
          item: getAbsoluteUrl(`/${yearSegment}`),
        },
        {
          "@type": "ListItem",
          position: 3,
          name: title,
          item: canonicalUrlString,
        },
      ],
    }
  : null;

const tagBreadcrumbs = (frontmatter.tags ?? []).map((tag) => ({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Tags",
      item: getAbsoluteUrl("/tags"),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: tag,
      item: getAbsoluteUrl(`/tags/${encodeURIComponent(tag)}`),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: canonicalUrlString,
    },
  ],
}));

// https://www.cemkiray.com/posts/how-to-add-json-ld-schema-in-astro/
// https://developers.google.com/search/docs/appearance/structured-data/article
// Construct JSON-LD data for the blog post
const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrlString,
  },
  headline: title,
  description: description,
  image: image?.src ? {
    "@type": "ImageObject",
    url: image.src,
    width: image.width,
    height: image.height,
    caption: frontmatter.imageAlt,
  } : undefined,
  author: {
    "@type": "Person",
    name: "David Gardiner",
    url: Astro.site?.toString(),
  },
  publisher: {
    "@type": "Organization",
    name: "David Gardiner",
    logo: {
      "@type": "ImageObject",
      url: "https://www.gravatar.com/avatar/37edf2567185071646d62ba28b868fab",
    },
  },
  datePublished: frontmatter.date,
  // dateModified: modDatetime?.toISOString(),
  keywords: frontmatter.tags?.join(", "),
  inLanguage: "en-AU",
};

const postJsonLd = [blogJsonLd, ...(archiveBreadcrumbs ? [archiveBreadcrumbs] : []), ...tagBreadcrumbs];

---

<BaseLayout 
  pageTitle={title} 
  frontmatter={{
    title,
    ...(description ? { description } : {}),
    ...(image ? { image } : {}),
    ...(frontmatter.imageAlt ? { imageAlt: frontmatter.imageAlt } : {}),
    tags: frontmatter.tags
  }} 
  canonicalUrl={canonicalUrlString}
>
  <slot name="head" slot="head" />

  {
    postJsonLd && (
      <script slot="head" is:raw is:inline
        type="application/ld+json"
        set:html={JSON.stringify(postJsonLd, null, 2)}
      />
    )
  }
  
  <h1>{frontmatter.title}</h1>

  <p><DateTimeComponent date={frontmatter.date} /></p>

  <p><em>{frontmatter.description}</em></p>

  <div class="tags">
    {
      frontmatter.tags.map((tag: string) => (
        <p class="tag">
          <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
        </p>
      ))
    }
  </div>

  <slot />

  <Disqus
    embed="https://davidgardiner.disqus.com/embed.js"
    url={Astro.url.toString()}
  />
</BaseLayout>
