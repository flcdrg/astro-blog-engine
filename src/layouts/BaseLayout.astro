---

import Footer from "../components/Footer.astro";
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import SiteTitle from "../components/SiteTitle.astro";
import { getCanonicalUrl } from "../scripts/canonical";

interface Props {
  pageTitle?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    image?: {
      src: string;
      width: number;
      height: number;
    };
    imageAlt?: string;
    tags?: string[];
  };
  canonicalUrl?: string | undefined;
}

const { pageTitle, frontmatter, canonicalUrl } = Astro.props;

// /@fs/... paths are Vite dev-server paths and cannot be made into valid public URLs
const absoluteImageUrl = frontmatter?.image?.src && !frontmatter.image.src.startsWith('/@')
  ? new URL(frontmatter.image.src, Astro.site ?? Astro.url).toString()
  : undefined;

// Site-wide JSON-LD structured data
const siteJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${Astro.site}#organization`,
      name: "David Gardiner",
      url: Astro.site,
      logo: "https://www.gravatar.com/avatar/37edf2567185071646d62ba28b868fab",
      sameAs: [
        "https://github.com/flcdrg",
        "https://www.linkedin.com/in/davidrgardiner/",
        "https://mastodon.online/@DavidRGardiner",
        "https://stackoverflow.com/users/25702/david-gardiner",
        "https://bsky.app/profile/david.gardiner.net.au",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${Astro.site}#website`,
      url: Astro.site,
      name: "Dave's Daydreams",
      description: "Blog by David Gardiner",
      publisher: { "@id": `${Astro.site}#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: `${Astro.site}tags/{search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={getCanonicalUrl(Astro.url, Astro.site)} />
    <slot name="head" />
    <title>{pageTitle || frontmatter?.title}</title>
    {
      frontmatter?.description && (
        <meta name="description" content={frontmatter.description} />
      )
    }
    {
      frontmatter?.description && (
        <meta name="og:description" property="og:description" content={frontmatter.description} />
      )
    }
    {
      pageTitle && (
        <meta name="og:title" property="og:title" content={pageTitle} />
      )
    }
    {
      frontmatter && (
        <meta name="og:type" property="og:type" content={frontmatter.tags ? "article" : "website"} />
      )
    }
    {
      canonicalUrl && (
        <meta name="og:url" property="og:url" content={canonicalUrl} />
      )
    }
    {
      absoluteImageUrl && (
        <meta name="og:image" property="og:image" content={absoluteImageUrl} />
      )
    }
    {
      frontmatter?.image?.width && (
        <meta name="og:image:width" property="og:image:width" content={frontmatter.image.width.toString()} />
      )
    }
    {
      frontmatter?.image?.height && (
        <meta name="og:image:height" property="og:image:height" content={frontmatter.image.height.toString()} />
      )
    }
    {
      frontmatter?.imageAlt && (
        <meta name="og:image:alt" property="og:image:alt" content={frontmatter.imageAlt} />
      )
    }
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      is:raw
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "a5756d0460ba41beba515f2b7666093d"}'
    ></script><!-- End Cloudflare Web Analytics -->

    <!-- Google tag (gtag.js) -->
    {
      Astro.site && Astro.site.href.includes('david.gardiner.net.au') && (
        <>
          <script is:raw is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RKLVTK1HGL"></script>
          <script is:raw is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'G-RKLVTK1HGL');
          </script>
        </>
      )
    }

    <script
      is:raw
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(siteJsonLd, null, 2)}
    />
  </head>
  <body>
    <header>
      <nav>
        <Navigation>
          <slot name="site-title" slot="site-title">
            <SiteTitle />
          </slot>
        </Navigation>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
