---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import getPostsByGroupCondition from "../scripts/getPostsByGroupCondition";
import { DateTime } from "luxon";
import onlyCurrent from "../scripts/filters";
import { getCanonicalUrl } from "../scripts/canonical";

const pageTitle = "Post Archive";

const posts = (await getCollection("blog")).filter(onlyCurrent);

const description = "Browse blog posts by year to explore past articles on .NET, Azure, DevOps, software engineering, and community events.";
const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Blog Archive",
  description: description,
  url: getCanonicalUrl(Astro.url, Astro.site),
};
---

<BaseLayout pageTitle={pageTitle} frontmatter={{ description: description }} pageJsonLd={collectionJsonLd}>
  <h1>Posts by year</h1>
  <ul>
    {
      Object.entries(
        getPostsByGroupCondition(
          posts,
          (post) => DateTime.fromISO(post.data.date).year
        )
      )
        .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
        .map(([year]) => (
          <li>
            <a href={`/${year}`}>{year}</a>
          </li>
        ))
    }
  </ul>
</BaseLayout>
