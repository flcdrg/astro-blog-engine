---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import BlogPostExcerpt from "../components/BlogPostExcerpt.astro";
import CustomImage from "../components/CustomImage.astro";
import DateTimeComponent from "../components/DateTimeComponent.astro";
import onlyCurrent from "../scripts/filters";

const pageTitle = "Dave's Daydreams - David Gardiner's Blog";

const allPosts = (await getCollection("blog"))
  .filter(onlyCurrent)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
  )
  .slice(0, 5);

const baseUrl = Astro.site ?? Astro.url;
const homepageUrl = new URL("/", baseUrl).toString();

const description = "Dave's Daydreams is David Gardiner's blog about .NET, Azure, DevOps, and software engineering, with practical notes, experiments, and occasional personal reflections.";

const homeJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${homepageUrl}#collection`,
      url: homepageUrl,
      name: pageTitle,
      description:
        description,
      isPartOf: {
        "@id": `${new URL("/", baseUrl).toString()}#website`,
      },
      mainEntity: {
        "@id": `${homepageUrl}#recent-posts`,
      },
    },
    {
      "@type": "ItemList",
      "@id": `${homepageUrl}#recent-posts`,
      name: "Recent posts",
      itemListOrder: "https://schema.org/ItemListOrderDescending",
      numberOfItems: allPosts.length,
      itemListElement: allPosts.map((post, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: new URL(post.id, baseUrl).toString(),
        name: post.data.title,
      })),
    },
  ],
};

const frontmatter = {
  description:
    description,
};

---

<BaseLayout pageTitle={pageTitle} frontmatter={frontmatter} pageJsonLd={homeJsonLd}>
  <link rel="sitemap" href="/sitemap-index.xml" slot="head" />

  <div slot="site-title">
    <h1>Dave's Daydreams</h1>
    <p>
      David Gardiner's blog of software development, .NET and other interesting
      things
    </p>
  </div>

  <p>Recent posts:</p>

  {
    allPosts.map(async (post) => (
      <section>
        <h2>
          <BlogPost url={post.id} title={post.data.title} />
        </h2>
        <p>
          <DateTimeComponent date={post.data.date} />{" "}
        </p>
        {post.data.image && (
          <CustomImage
            desktopImgUrl={post.data.image!}
            alt={post.data.imageAlt}
          />
        )}
        <BlogPostExcerpt
          body={post.data.description || post.body}
          length={500}
        />{" "}
        <a href={encodeURI(post.id)}>Read more...</a>
        <div style="clear: both" />
        <div class="tags">
          {post.data.tags.map((tag: string) => (
            <p class="tag">
              <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
            </p>
          ))}
        </div>
      </section>
    ))
  }

  <p>Older posts can be found in the <a href="/archive">archive</a>.</p>
</BaseLayout>

<style>
  .list-none {
    list-style-type: none;
  }
</style>
